}

input {
  width: 100%;
  padding: 12px;
  font-size: 1rem;
  border: 1px solid #ccc;
  border-radius: 4px;
}

input:focus {
  outline: 3px solid #005fcc;
  outline-offset: 2px;
}

input[aria-invalid="true"] {
  border-color: #b00020;
}

button {
  padding: 12px;
  font-size: 1rem;
  border: none;
  border-radius: 4px;
  background: #005fcc;
  color: #fff;
  cursor: pointer;
  transition: background 0.2s ease;
}

button:hover,
button:focus {
  background: #0045a3;
}

.toggle-password {
  margin-top: 8px;
  background: #eee;
  color: #000;
}

.error {
  color: #b00020;
  font-size: 0.9rem;
  margin-top: 4px;
  display: block;
}

.success {
  color: #007700;
  font-size: 0.95rem;
  margin-top: 8px;
  display: block;
}
</style>
</head>
<body>

<main>
  <h1 id="login-title">Prijava na račun</h1>

  <!-- Error summary -->
  <div id="error-summary" role="alert" aria-live="assertive" tabindex="-1">
    <p>Pronađene su greške:</p>
    <ul></ul>
  </div>

  <form id="loginForm" novalidate aria-labelledby="login-title" aria-describedby="form-instructions">
    <p id="form-instructions">Molimo unesite email i lozinku. Sva polja su obavezna.</p>

    <div>
      <label for="email">Email</label>
      <input type="email" id="email" name="email" required aria-describedby="email-error">
      <span id="email-error" class="error" aria-live="polite"></span>
    </div>

    <div>
      <label for="password">Lozinka</label>
      <input type="password" id="password" name="password" required minlength="6" aria-describedby="password-error">
      <button type="button" class="toggle-password" aria-pressed="false">Prikaži lozinku</button>
      <span id="password-error" class="error" aria-live="polite"></span>
    </div>

    <button type="submit">Prijava</button>
    <span id="success-message" class="success" aria-live="polite"></span>
  </form>
</main>

<script>
const form = document.getElementById("loginForm");
const email = document.getElementById("email");
const password = document.getElementById("password");
const emailError = document.getElementById("email-error");
const passwordError = document.getElementById("password-error");
const successMessage = document.getElementById("success-message");
const errorSummary = document.getElementById("error-summary");
const errorList = errorSummary.querySelector("ul");
const togglePasswordBtn = document.querySelector(".toggle-password");

// Validacija emaila
function validateEmail() {
  if (!email.value.trim()) {
    emailError.textContent = "Email je obavezan.";
    email.setAttribute("aria-invalid", "true");
    return false;
  } else if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email.value)) {
    emailError.textContent = "Unesite ispravnu email adresu.";
    email.setAttribute("aria-invalid", "true");
    return false;
  } else {
    emailError.textContent = "";
    email.removeAttribute("aria-invalid");
    return true;
  }
}

// Validacija lozinke
function validatePassword() {
  if (!password.value.trim()) {
    passwordError.textContent = "Lozinka je obavezna.";
    password.setAttribute("aria-invalid", "true");
    return false;
  } else if (password.value.length < 6) {
    passwordError.textContent = "Lozinka mora imati najmanje 6 znakova.";
    password.setAttribute("aria-invalid", "true");
    return false;
  } else {
    passwordError.textContent = "";
    password.removeAttribute("aria-invalid");
    return true;
  }
}

// Real-time validacija
email.addEventListener("input", validateEmail);
password.addEventListener("input", validatePassword);

// Toggle password
togglePasswordBtn.addEventListener("click", () => {
  if (password.type === "password") {
    password.type = "text";
    togglePasswordBtn.textContent = "Sakrij lozinku";
    togglePasswordBtn.setAttribute("aria-pressed", "true");
  } else {
    password.type = "password";
    togglePasswordBtn.textContent = "Prikaži lozinku";
    togglePasswordBtn.setAttribute("aria-pressed", "false");
  }
});

// Submit forme s error summary
form.addEventListener("submit", function(e) {
  e.preventDefault();
  errorList.innerHTML = "";
  errorSummary.style.display = "none";

  const emailValid = validateEmail();
  const passwordValid = validatePassword();
  let firstErrorField = null;

  if (!emailValid) {
    errorList.innerHTML += "<li>Email: " + emailError.textContent + "</li>";
    if (!firstErrorField) firstErrorField = email;
  }
  if (!passwordValid) {
    errorList.innerHTML += "<li>Lozinka: " + passwordError.textContent + "</li>";
    if (!firstErrorField) firstErrorField = password;
  }

  if (!emailValid || !passwordValid) {
    errorSummary.style.display = "block";
    errorSummary.focus();
    firstErrorField.focus();
    return;
  }

  // Forma validna
  successMessage.textContent = "Prijava uspješna! (simulacija)";
  errorSummary.style.display = "none";
});
</script>

</body>
</html>



